"""Runtime config artifacts for `react_app`.

Emits three targets from an `{KEY: dev_default}` dict:

  * `:{name}_env_tpl`      — env.js.tpl with `${KEY}` placeholders for
                              envsubst-at-container-start in prod images
  * `:{name}_env_dev`      — env.js with literal dev defaults for the devserver
  * `:{name}_env_component` — react_component wrapping a generated typed
                              getEnv() helper; the key union is derived from
                              the dict so `getEnv("TYPO")` is a TS compile
                              error

See `react_app(runtime_config = ...)`.
"""

load("@bazel_skylib//rules:write_file.bzl", "write_file")
load(":react_component.bzl", "react_component")

_ALPHA_UPPER = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
_DIGITS = "0123456789"

def _is_upper(ch):
    return ch in _ALPHA_UPPER.elems()

def _is_key_rest(ch):
    return ch in _ALPHA_UPPER.elems() or ch in _DIGITS.elems() or ch == "_"

def validate_runtime_config(cfg):
    """Fails with a clear message if cfg is not `{UPPER_SNAKE: string}`."""
    if type(cfg) != "dict":
        fail("runtime_config must be a dict, got {}".format(type(cfg)))
    for k, v in cfg.items():
        if type(k) != "string" or not k:
            fail("runtime_config: keys must be non-empty strings, got {}".format(k))
        if not _is_upper(k[0]):
            fail("runtime_config: key \"{}\" must match ^[A-Z][A-Z0-9_]*$".format(k))
        for ch in k[1:].elems():
            if not _is_key_rest(ch):
                fail("runtime_config: key \"{}\" must match ^[A-Z][A-Z0-9_]*$".format(k))
        if type(v) != "string":
            fail("runtime_config: value for \"{}\" must be a string, got {}".format(k, type(v)))

def _js_string_escape(s):
    # Minimal escape for JSON-style double-quoted string literals.
    return s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n").replace("\r", "\\r").replace("\t", "\\t")

def _env_js_lines(cfg, dev):
    keys = sorted(cfg.keys())
    lines = ["window.__ENV__ = {"]
    for i, k in enumerate(keys):
        sep = "," if i < len(keys) - 1 else ""
        if dev:
            lines.append("  \"{}\": \"{}\"{}".format(k, _js_string_escape(cfg[k]), sep))
        else:
            lines.append("  \"{}\": \"${{{}}}\"{}".format(k, k, sep))
    lines.append("};")
    lines.append("")
    return lines

def _env_ts_lines(cfg):
    keys = sorted(cfg.keys())
    union = " | ".join(["\"{}\"".format(k) for k in keys])
    return [
        "// Generated by react_app runtime_config — do not edit.",
        "type Key = {};".format(union),
        "",
        "export function getEnv<K extends Key>(key: K): string {",
        "  const env = (globalThis as unknown as { __ENV__?: Record<string, string> }).__ENV__;",
        "  if (!env || typeof env[key] !== \"string\") {",
        "    throw new Error(`runtime config: missing key \"${key}\"`);",
        "  }",
        "  return env[key];",
        "}",
        "",
    ]

def runtime_config_artifacts(name, runtime_config, forward_kwargs = {}):
    """Emit the three runtime_config artifact targets for `name`.

    Args:
        name: parent react_app name; artifacts are prefixed `{name}_env_*`.
        runtime_config: validated dict of `{UPPER_SNAKE: dev_default}`.
        forward_kwargs: subset of react_app kwargs to propagate to each
            generated target (typically `visibility`, `tags`, `testonly`).
            When `visibility` is absent, defaults to public on the env
            component so pages in subpackages can import `getEnv` without
            the user having to configure cross-package visibility.
    """
    component_kwargs = dict(forward_kwargs)
    if "visibility" not in component_kwargs:
        component_kwargs["visibility"] = ["//visibility:public"]

    write_file(
        name = name + "_env_tpl",
        out = name + "_env.js.tpl",
        content = _env_js_lines(runtime_config, dev = False),
        **forward_kwargs
    )

    write_file(
        name = name + "_env_dev",
        out = name + "_env_dev.js",
        content = _env_js_lines(runtime_config, dev = True),
        **forward_kwargs
    )

    write_file(
        name = name + "_env_ts_src",
        out = name + "_env.ts",
        content = _env_ts_lines(runtime_config),
        **component_kwargs
    )

    react_component(
        name = name + "_env_component",
        srcs = [name + "_env.ts"],
        _export_test = False,
        **component_kwargs
    )
