apt = use_extension("@rules_distroless//apt:extensions.bzl", "apt")

# `mergedusr = True` rewrites /bin, /sbin, /lib* under /usr to match Debian's
# UsrMerge layout (the only one supported on bookworm+). Without it, packages
# that ship the same path under both /bin and /usr/bin produce duplicate-path
# errors when assembling OCI layers. https://wiki.debian.org/UsrMerge
#
# `package_template` overrides the upstream rules_distroless per-.deb BUILD
# template with our own (loads `dpkg_statusd` + `package_metadata`).
apt.install(
    name = "debian",
    distro = "debian-unstable",
    lock = "//oci/distroless:debian.lock.json",
    manifest = "//oci/distroless:debian.yaml",
    mergedusr = True,
    package_template = "//oci/distroless/common:package.BUILD.tmpl",
)
apt.install(
    name = "nginx_stable",
    distro = "debian-unstable",
    lock = "//oci/distroless/nginx:nginx-stable.lock.json",
    manifest = "//oci/distroless/nginx:nginx-stable.yaml",
    mergedusr = True,
    package_template = "//oci/distroless/common:package.BUILD.tmpl",
)
apt.install(
    name = "nginx_mainline",
    distro = "debian-unstable",
    lock = "//oci/distroless/nginx:nginx-mainline.lock.json",
    manifest = "//oci/distroless/nginx:nginx-mainline.yaml",
    mergedusr = True,
    package_template = "//oci/distroless/common:package.BUILD.tmpl",
)
apt.install(
    name = "workstation",
    distro = "debian-unstable",
    lock = "//devtools/workstation:debian.lock.json",
    manifest = "//devtools/workstation:debian.yaml",
    mergedusr = True,
    package_template = "//oci/distroless/common:package.BUILD.tmpl",
)
use_repo(apt, "debian", "nginx_mainline", "nginx_stable", "workstation")

# Hummingbird RPM repository — sourced from a public Hummingbird snapshot
# (see ADR 0007). The lockfile pins `revision` + per-rpm SHA256; refresh
# via `bazel run @hummingbird//:pin` once the pin tool is wired (currently
# hand-written for the tracer-bullet tzdata-only state).
rpm = use_extension("@rules_rpm//rpm:extensions.bzl", "rpm")
rpm.install(
    name = "hummingbird",
    architectures = [
        "x86_64",
        "aarch64",
    ],
    # Matches grype's `hummingbird:distro:hummingbird:1` provider — drives
    # per-package secdb routing on SBOM scans. Without this qualifier, grype
    # falls back to NVD-CPE matching and silently misses Hummingbird's
    # backported advisories.
    distro = "hummingbird-1",
    gpg_key = "//:hummingbird-release.pgp",
    lock_file = "//:hummingbird.lock.json",
    # Closed manifest of *root* packages; pin walks rpm:requires and adds
    # transitively reachable packages to the lockfile (same posture as
    # @debian's apt resolver). Trim entries here only if you also want
    # their transitives gone — bare-bones cc needs glibc + libgcc +
    # libstdc++ + openssl-libs as roots; ca-certificates / mailcap /
    # tzdata stay declared because static composes them directly even
    # though glibc would otherwise pull ca-certificates transitively.
    packages = [
        "bash",
        "busybox",
        "ca-certificates",
        "coreutils",
        "glibc",
        "grep",
        "libacl",
        "libatomic",
        "libattr",
        "libcap",
        "libgcc",
        "libselinux",
        "libsepol",
        "libstdc++",
        "mailcap",
        "mawk",
        "ncurses-libs",
        "openssl-libs",
        "pcre2",
        "sed",
        "tzdata",
    ],
    # Per-arch subtrees (x86_64/, aarch64/) live under this base. Each
    # lockfile entry's `path` prefixes the right subtree (noarch entries
    # use either subtree — same bytes).
    repo_url = "https://koji-s3-cache.hummingbird-project.io/packages.redhat.com/api/pulp-content/public-hummingbird",
    # Hummingbird's RHPG snapshot publishes per-RPM GPG signatures and
    # sigstore attestations under `metadata/attestations/`, but no
    # detached signature over `repomd.xml` (verified empirically —
    # repodata listing contains only `repomd.xml`, `*-primary.xml.gz`,
    # `*-filelists.xml.gz`, `*-other.xml.gz`). Lock-time trust degrades
    # to TLS; build-time per-RPM verification in rpm-extract remains the
    # binary-integrity anchor. See ADR 0007's 2026-05-19 amendment.
    repomd_signature = "optional",
)

# nginx.org's own RPM repositories, mirroring how we already use their apt
# repos on the Debian side. Stable and mainline are first-class separate
# repos (no version-constraint pinning needed); each ships a single
# self-contained `nginx` rpm — no nginx/nginx-core/nginx-filesystem
# decomposition and none of Hummingbird's gperftools / libunwind /
# libxcrypt linkage. Lockfiles live alongside the consuming BUILD in
# //oci/distroless/nginx/ — same convention as the apt-side
# nginx-{stable,mainline}.lock.json. rhel/10 binaries match Hummingbird's
# glibc/openssl baseline at runtime.
rpm.install(
    name = "nginx_stable_rpm",
    architectures = [
        "x86_64",
        "aarch64",
    ],
    # Routes via Hummingbird's secdb even though the binary came from
    # nginx.org. RHEL-10's secdb has CVE entries for nginx but no fix
    # data (RHEL doesn't ship nginx) — every flag would be a no-fix
    # false positive. Hummingbird's secdb has accurate version-range
    # data: all `< 1.30.0-1.hum1` advisories pass cleanly (we ship
    # 1.30.1+), and the only flag is CVE-2026-42945's release-suffix-
    # strict `< 1.30.1-1.hum1` constraint on stable, which is VEXed in
    # //oci/distroless/nginx/BUILD with `vulnerable_code_not_present`
    # because upstream 1.30.1 carries the fix regardless of release tag.
    distro = "hummingbird-1",
    gpg_key = "//oci/distroless/nginx:nginx_signing.key",
    lock_file = "//oci/distroless/nginx:nginx-stable.hummingbird.lock.json",
    packages = ["nginx"],
    # Surfaces `pkg:rpm/nginx.org/nginx@...` in the image SBOM so grype
    # routes lookups to NVD-CPE rather than `pkg:rpm/nginx_stable_rpm/...`
    # (no provider matches). Crucially decouples nginx from the
    # `ID=hummingbird` image-scan routing: Hummingbird's secdb advisory
    # for CVE-2026-42945 is release-suffix-strict (`< 1.30.1-1.hum1`)
    # and would falsely flag nginx.org's `1.30.1-1.el10.ngx` even though
    # the upstream fix is in 1.30.1 itself. With this namespace, grype's
    # SBOM-scan correctly treats nginx as an nginx.org-provided package
    # and applies NVD's upstream version-range matching.
    purl_namespace = "nginx.org",
    repo_url = "https://nginx.org/packages/rhel/10",
)
rpm.install(
    name = "nginx_mainline_rpm",
    architectures = [
        "x86_64",
        "aarch64",
    ],
    distro = "hummingbird-1",
    gpg_key = "//oci/distroless/nginx:nginx_signing.key",
    lock_file = "//oci/distroless/nginx:nginx-mainline.hummingbird.lock.json",
    packages = ["nginx"],
    purl_namespace = "nginx.org",
    repo_url = "https://nginx.org/packages/mainline/rhel/10",
)
use_repo(rpm, "hummingbird", "nginx_mainline_rpm", "nginx_stable_rpm")

