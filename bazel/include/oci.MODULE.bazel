# Node.js runtime tarballs from nodejs.org. Consumed by //oci/distroless/nodejs
# (ADR 0007 step 6, the "marquee demo" distroless node on Hummingbird's glibc).
# Only `bin/node` is shipped in the image; npm/npx/corepack/headers/docs are
# left in the bazel-out tree and never make it into the layer.
#
# To refresh:
#   curl -fsSL https://nodejs.org/dist/index.json | jq '.[] | select(.version | startswith("v26."))[0]'
#   curl -fsSL https://nodejs.org/dist/v<version>/SHASUMS256.txt | grep linux
_NODEJS_TARBALL_BUILD_FILE_CONTENT = """\
package(default_visibility = ["//visibility:public"])
exports_files(["bin/node"])
"""

[
    http_archive(
        name = "nodejs_{}_{}".format(major, arch),
        build_file_content = _NODEJS_TARBALL_BUILD_FILE_CONTENT,
        sha256 = sha,
        strip_prefix = "node-v{}-linux-{}".format(
            full_version,
            "x64" if arch == "amd64" else "arm64",
        ),
        url = "https://nodejs.org/dist/v{}/node-v{}-linux-{}.tar.xz".format(
            full_version,
            full_version,
            "x64" if arch == "amd64" else "arm64",
        ),
    )
    for major, full_version, sha_by_arch in [
        (
            "20",
            "20.20.2",
            {
                "amd64": "df770b2a6f130ed8627c9782c988fda9669fa23898329a61a871e32f965e007d",
                "arm64": "73093db209e4e9e09dd7d15a47aeaab1b74833830df03efa5f942a1122c5fa71",
            },
        ),
        (
            "24",
            "24.15.0",
            {
                "amd64": "472655581fb851559730c48763e0c9d3bc25975c59d518003fc0849d3e4ba0f6",
                "arm64": "f3d5a797b5d210ce8e2cb265544c8e482eaedcb8aa409a8b46da7e8595d0dda0",
            },
        ),
        (
            "26",
            "26.1.0",
            {
                "amd64": "9fc6f21b6c4a62439727123e510e9c39febb2f563738f4927cd3e0b288c9b3c9",
                "arm64": "058f00fe6c84f804b4b96aab377f76ed57dd0be5f10af4dcc0fded172746f366",
            },
        ),
    ]
    for arch, sha in sha_by_arch.items()
]

# Eclipse Temurin JRE tarballs from Adoptium GitHub releases. Consumed by
# //oci/distroless/java — the headless JRE ships under /jre/, mirroring
# nodejs's /nodejs/ prefix so the host distro's PATH never resolves to it.
# The image entrypoint is the absolute path /jre/bin/java.
#
# Policy: latest 3 LTS only, no non-LTS. Auto-rolls — when 29 ships in
# 2027, 17 rolls off and 29 lands here. Adoptium's LTS list is
# [8, 11, 17, 21, 25]; we explicitly do NOT ship 8/11 (EOL trajectory,
# tiny incremental users on new infra — same posture as Google Distroless).
#
# To refresh:
#   curl -fsSL https://api.adoptium.net/v3/info/available_releases
#   curl -fsSL "https://api.adoptium.net/v3/assets/latest/<V>/hotspot?architecture=x64&image_type=jre&os=linux&vendor=eclipse"
_TEMURIN_BUILD_FILE_CONTENT = """\
package(default_visibility = ["//visibility:public"])
filegroup(
    name = "all",
    srcs = glob(["**"], exclude = ["BUILD*", "REPO*", "WORKSPACE*", "MODULE*"], allow_empty = False),
)
"""

# JRE (release variant) and JDK (debug variant) per (major, arch). The JDK
# carries jstack/jcmd/jmap/javac for `kubectl exec`-style production
# diagnostics — Google Distroless's `:debug` variant uses the same trick.
# Versions are kept in lockstep across image_type because mixing build
# numbers would shift the CPE component the SBOM declares between modes.
[
    http_archive(
        name = "temurin_{}_{}_{}".format(image_type, major, arch),
        build_file_content = _TEMURIN_BUILD_FILE_CONTENT,
        sha256 = sha,
        strip_prefix = "jdk-{}+{}{}".format(
            version,
            build,
            "-jre" if image_type == "jre" else "",
        ),
        url = "https://github.com/adoptium/temurin{}-binaries/releases/download/jdk-{}%2B{}/OpenJDK{}U-{}_{}_linux_hotspot_{}_{}.tar.gz".format(
            major,
            version,
            build,
            major,
            image_type,
            "x64" if arch == "amd64" else "aarch64",
            version,
            build,
        ),
    )
    for image_type, sha_by_major in [
        (
            "jre",
            {
                "17": (
                    "17.0.19",
                    "10",
                    {
                        "amd64": "adb5a2364baa51de1ef91bb9911f5a61d24b045fe1d6647cb8050272a3a8ee75",
                        "arm64": "aae834297a87736869745be7c1fca3207ea9167c5824f41c88b0ebb2e3ccb9b1",
                    },
                ),
                "21": (
                    "21.0.11",
                    "10",
                    {
                        "amd64": "e5038aae3ca9ff670bc696496b0728dbd23d280026bad30291cb919221ecfdcb",
                        "arm64": "fa23d9d9945053e67bcc7638410eabf1e17a7672c7c95a24f70cd08b8407d36e",
                    },
                ),
                "25": (
                    "25.0.3",
                    "9",
                    {
                        "amd64": "487ad434d8b121ae3902d5ad9cb830cd8e1f75fefad6e2ba80f89d60e3db95d7",
                        "arm64": "d12d5b19ff7f6c4a99fd4f9eecede2c96e64df7d1f41cc84f2e9c9b38408600b",
                    },
                ),
            },
        ),
        (
            "jdk",
            {
                "17": (
                    "17.0.19",
                    "10",
                    {
                        "amd64": "d8afc263758141a66e0e3aafc321e783f7016696f4eaea067d340a269037d331",
                        "arm64": "83a52172678ec8975164648654869cb2e71d7c748b47aca94b29bbfa10c18e81",
                    },
                ),
                "21": (
