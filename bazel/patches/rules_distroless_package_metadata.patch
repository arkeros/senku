diff --git a/apt/private/deb_translate_lock.bzl b/apt/private/deb_translate_lock.bzl
index fc0fc71..2f06ee9 100644
--- a/apt/private/deb_translate_lock.bzl
+++ b/apt/private/deb_translate_lock.bzl
@@ -4,6 +4,31 @@ load(":lockfile.bzl", "lockfile")
 load(":starlark_codegen_utils.bzl", "starlark_codegen_utils")
 load(":util.bzl", "util")
 
+# Encodes the subset of Debian version characters that must be percent-encoded
+# inside a purl (https://github.com/package-url/purl-spec). Debian versions
+# routinely contain `+` (e.g. `2.41-12+deb13u2`) and `:` (epoch separator,
+# e.g. `1:1.0-1`); `~` is allowed unescaped.
+def _purl_encode_version(version):
+    return version.replace("+", "%2B").replace(":", "%3A")
+
+def _deb_purl(name, version, arch, distro, source):
+    # Namespace is hardcoded to "debian" — covers Debian-derived apt repos
+    # (incl. rules_distroless's bullseye/bookworm/trixie and downstream debian-style repos).
+    purl = "pkg:deb/debian/{name}@{version}?arch={arch}".format(
+        name = name,
+        version = _purl_encode_version(version),
+        arch = arch,
+    )
+    if distro:
+        purl += "&distro={distro}".format(distro = distro)
+
+    # `upstream=<source>` lets advisory matchers (e.g. grype) bridge from
+    # binary package to source package — Debian indexes CVEs by source name
+    # (`glibc`), not binary (`libc6`). Without it, advisory lookup misses.
+    if source and source != name:
+        purl += "&upstream={source}".format(source = source)
+    return purl
+
