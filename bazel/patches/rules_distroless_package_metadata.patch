+def _source_name(package):
+    # apt index `Source:` field: "<name>" or "<name> (<version>)". When
+    # absent, source name defaults to the binary `Package:` name (Debian
+    # convention for single-source-package debs).
+    raw = package.get("Source", "").strip()
+    if not raw:
+        return package["Package"]
+    return raw.split(" ", 1)[0]
+
