# Ignore all bazel-* symlinks. There is no full list since this can change
# based on the name of the directory bazel is cloned into.
/bazel-*

# User-specific bazel configuration
.bazelrc.user

node_modules/

# Terraform
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfplan

# Bazel-materialized tfvars (digest pins). Regenerated by
# `bazel run :image_tfvars_update` targets; checked-in copy would rotate on
# every image build.
**/*.auto.tfvars.json

.DS_Store
